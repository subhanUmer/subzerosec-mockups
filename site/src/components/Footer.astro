---
import { FOOTER_COLS, SOCIAL } from '../data/site.ts';
---
<footer class="closer">
  <div class="wrap">
    <div class="fgrid">
      <div class="about"><a class="brand" href="index.html"><img src="assets/logo.png" alt="" />SubZero<span class="z">Sec</span></a>
        <p>Offensive security that finds exploitable weaknesses before adversaries do. Before Zero. Beyond Breach.</p>
        <div class="fsocial">{SOCIAL.map((s) => (<a href={s.href} aria-label={s.label}>{s.label}</a>))}</div>
      </div>
      {FOOTER_COLS.map((col) => (
        <div class="fcol"><h4>{col.h}</h4>{col.links.map((l) => (<a href={l.href}>{l.t}</a>))}</div>
      ))}
    </div>
    <div class="fbar"><span>&copy; 2026 SubZeroSec (Pvt) Ltd. - Islamabad, Pakistan</span><span>Before Zero. Beyond Breach.</span></div>
  </div>
</footer>
