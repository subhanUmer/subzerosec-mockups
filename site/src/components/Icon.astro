---
/**
 * Central registry for the site's hand-drawn line icons.
 * One source of truth — edit a glyph here and it updates everywhere.
 * Every icon shares the 24x24 viewBox, fill:none, stroke:currentColor
 * convention; only the stroke-width varies per glyph (kept faithful to
 * the original hand-rolled markup).
 */
interface Props {
  name: keyof typeof ICONS;
  class?: string;
  [key: string]: unknown;
}

const ICONS = {
  check:          { sw: 3,   d: '<path d="M5 12l5 5L20 7"/>' },
  'arrow-right':  { sw: 2,   d: '<path d="M5 12h14M13 6l6 6-6 6"/>' },
  'chevron-down': { sw: 2.2, d: '<path d="M6 9l6 6 6-6"/>' },
  burger:         { sw: 2,   d: '<path d="M3 6h18M3 12h18M3 18h18"/>' },
  vapt:           { sw: 1.7, d: '<circle cx="12" cy="12" r="8"/><path d="M12 1.5v4.5M12 18v4.5M1.5 12h4.5M18 12h4.5"/><circle cx="12" cy="12" r="2.6"/><path d="M12 12h.01"/>' },
  'red-team':     { sw: 1.8, d: '<path d="M6 21V3.5"/><path d="M6 5l11.5 3.1L6 11.2"/>' },
  'threat-hunting': { sw: 1.7, d: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.3"/><path d="M12 12l5-3.4"/><circle cx="17" cy="8.6" r="1.15" fill="currentColor" stroke="none"/>' },
  osint:          { sw: 1.7, d: '<path d="M2.5 12C4 8 7.5 5.8 12 5.8S20 8 21.5 12C20 16 16.5 18.2 12 18.2S4 16 2.5 12Z"/><circle cx="12" cy="12" r="2.7"/>' },
  'attack-surface': { sw: 1.7, d: '<path d="M4 9V6a2 2 0 0 1 2-2h3M20 9V6a2 2 0 0 0-2-2h-3M4 15v3a2 2 0 0 0 2 2h3M20 15v3a2 2 0 0 1-2 2h-3"/><circle cx="9.5" cy="10.5" r="1.2" fill="currentColor" stroke="none"/><circle cx="14.5" cy="10.5" r="1.2" fill="currentColor" stroke="none"/><circle cx="12" cy="14.6" r="1.2" fill="currentColor" stroke="none"/>' },
  mail:           { sw: 1.7, d: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="M3.5 7.5l7.3 5.2a2 2 0 0 0 2.4 0L20.5 7.5"/>' },
  location:       { sw: 1.7, d: '<path d="M12 21s-7-5.2-7-11a7 7 0 0114 0c0 5.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/>' },
} as const;

const { name, class: className, ...rest } = Astro.props;
const icon = ICONS[name];
if (!icon) throw new Error(`Icon "${String(name)}" is not in the registry`);
---
<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={icon.sw}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={icon.d}
  {...rest}
></svg>
