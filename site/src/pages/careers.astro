---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
const title = "Careers - SubZeroSec";
const description = "Open roles at SubZeroSec. Join the offense.";
---
<Base title={title} description={description} active="company">
<section class="phead">
  <div class="phbg" aria-hidden="true"></div>
  <div class="wrap">
    <div class="crumb"><a href="index.html">Home</a> <i>/</i> <a href="company.html">About</a> <i>/</i> <span>Careers</span></div><span class="eyebrow">CAREERS</span>
    <h1>Join the offense.</h1>
    <p class="lead">We build a team of operators who find what others miss. Remote-first, senior, and obsessed with proving real impact.</p>
  </div>
</section>
<section class="sec light cutA"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="shead"><span class="eyebrow">Open roles</span><h2>Where you fit in.</h2></div><div class="jobs"><a class="jobrow" href="job-senior-penetration-tester.html"><div><h3>Senior Penetration Tester</h3><div class="meta">Offensive Security &middot; Senior &middot; Remote (UK/EU) &middot; Full-time</div><p>Lead manual, exploit-driven assessments across web, API, network, and cloud targets, and set the technical bar for the findings we ship.</p></div><span class="lm">View role <Icon name="arrow-right" /></span></a><a class="jobrow" href="job-red-team-operator.html"><div><h3>Red Team Operator</h3><div class="meta">Adversary Emulation &middot; Mid-Senior &middot; Remote (UK/EU) &middot; Full-time</div><p>Run objective-based adversary emulation against mature, defended environments and measure how well clients can detect and respond.</p></div><span class="lm">View role <Icon name="arrow-right" /></span></a><a class="jobrow" href="job-threat-intelligence-analyst.html"><div><h3>Threat Intelligence Analyst</h3><div class="meta">Threat Intelligence &middot; Mid &middot; Remote (UK/EU) &middot; Full-time</div><p>Turn raw adversary behavior into the scenarios our red team runs and the hypotheses our hunters chase across client environments.</p></div><span class="lm">View role <Icon name="arrow-right" /></span></a><a class="jobrow" href="job-security-consultant-delivery.html"><div><h3>Security Consultant (Delivery)</h3><div class="meta">Client Delivery &middot; Mid &middot; Remote (UK/EU) &middot; Full-time</div><p>Own the client experience from scoping to verified remediation, making sure technical rigor lands as clear, actionable outcomes.</p></div><span class="lm">View role <Icon name="arrow-right" /></span></a></div></div></section>
<section class="sec dark"><div class="wrap"><div class="shead"><span class="eyebrow">Why work here</span><h2>What you can expect.</h2></div><ul class="checks twocol-checks"><li><span class="ck"><Icon name="check" /></span> Manual craft over automated noise</li><li><span class="ck"><Icon name="check" /></span> Reports anyone can act on</li><li><span class="ck"><Icon name="check" /></span> Remote-first, outcome-focused</li><li><span class="ck"><Icon name="check" /></span> Ongoing research and conference time</li><li><span class="ck"><Icon name="check" /></span> Vetted, certified, trusted operators</li><li><span class="ck"><Icon name="check" /></span> Mentorship and a high technical bar</li></ul></div></section>
<section class="sec light cutC"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="cta-in"><span class="eyebrow">Get ahead of zero</span><h2>Ready to see yourself the way an <span class="r">adversary would?</span></h2><p>Book a scoped assessment - we will map what is reachable, prove what is exploitable, and give you a ranked path to closing it before someone finds it first.</p><a href="contact.html" class="btn btn-fill">Book a free scoping call <Icon name="arrow-right" /></a></div></div></section>
</Base>
