---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
const title = "Security Consultant (Delivery) - Careers - SubZeroSec";
const description = "Own the client experience from scoping to verified remediation, making sure technical rigor lands as clear, actionable outcomes.";
---
<Base title={title} description={description} active="company">
<section class="phead">
  <div class="phbg" aria-hidden="true"></div>
  <div class="wrap">
    <div class="crumb"><a href="index.html">Home</a> <i>/</i> <a href="careers.html">Careers</a> <i>/</i> <span>Security Consultant (Delivery)</span></div><span class="eyebrow">Client Delivery</span>
    <h1>Security Consultant (Delivery)</h1>
    <p class="lead">Client Delivery &amp;middot; Mid &amp;middot; Remote (UK/EU) &amp;middot; Full-time</p>
  </div>
</section>
<section class="sec light cutA"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="detail"><div class="dprose"><p class="rolesummary">Own the client experience from scoping to verified remediation, making sure technical rigor lands as clear, actionable outcomes.</p><h3 class="colh">What you will do</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Scope engagements with clients and translate needs into clear statements of work</li><li><span class="ck"><Icon name="check" /></span> Coordinate delivery across testing, red-team, and intelligence teams</li><li><span class="ck"><Icon name="check" /></span> Guide clients through findings, prioritization, and remediation planning</li><li><span class="ck"><Icon name="check" /></span> Track remediation to closure and coordinate retests</li><li><span class="ck"><Icon name="check" /></span> Act as the trusted point of contact throughout the engagement lifecycle</li></ul><h3 class="colh">What we are looking for</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Experience in security consulting, delivery, or technical program management</li><li><span class="ck"><Icon name="check" /></span> Enough technical depth to discuss findings credibly with engineers</li><li><span class="ck"><Icon name="check" /></span> Excellent communication and stakeholder-management skills</li><li><span class="ck"><Icon name="check" /></span> Strong organization across concurrent engagements</li><li><span class="ck"><Icon name="check" /></span> A consultative, outcome-focused approach to client relationships</li></ul><h3 class="colh">Nice to have</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Background in a regulated sector such as finance or healthcare</li><li><span class="ck"><Icon name="check" /></span> Familiarity with SOC 2, ISO 27001, or PCI DSS requirements</li></ul></div><aside class="dside"><div class="aside-card"><h4>Role details</h4><div class="kv"><span>Team</span><b>Client Delivery</b></div><div class="kv"><span>Level</span><b>Mid</b></div><div class="kv"><span>Location</span><b>Remote (UK/EU)</b></div><div class="kv"><span>Type</span><b>Full-time</b></div><div class="kv"><span>Posted</span><b>1 Jun 2026</b></div></div><a class="btn btn-fill asidebtn" href="mailto:careers@subzerosec.com?subject=Application: Security Consultant (Delivery)">Apply for this role <Icon name="arrow-right" /></a></aside></div></div></section>
<section class="sec light cutC"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="cta-in"><span class="eyebrow">Get ahead of zero</span><h2>Ready to see yourself the way an <span class="r">adversary would?</span></h2><p>Book a scoped assessment - we will map what is reachable, prove what is exploitable, and give you a ranked path to closing it before someone finds it first.</p><a href="contact.html" class="btn btn-fill">Book a free scoping call <Icon name="arrow-right" /></a></div></div></section>
</Base>
