---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
const title = "Threat Intelligence Analyst - Careers - SubZeroSec";
const description = "Turn raw adversary behavior into the scenarios our red team runs and the hypotheses our hunters chase across client environments.";
---
<Base title={title} description={description} active="company">
<section class="phead">
  <div class="phbg" aria-hidden="true"></div>
  <div class="wrap">
    <div class="crumb"><a href="index.html">Home</a> <i>/</i> <a href="careers.html">Careers</a> <i>/</i> <span>Threat Intelligence Analyst</span></div><span class="eyebrow">Threat Intelligence</span>
    <h1>Threat Intelligence Analyst</h1>
    <p class="lead">Threat Intelligence &amp;middot; Mid &amp;middot; Remote (UK/EU) &amp;middot; Full-time</p>
  </div>
</section>
<section class="sec light cutA"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="detail"><div class="dprose"><p class="rolesummary">Turn raw adversary behavior into the scenarios our red team runs and the hypotheses our hunters chase across client environments.</p><h2 class="colh">What you will do</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Track threat groups and campaigns relevant to the sectors we serve</li><li><span class="ck"><Icon name="check" /></span> Translate adversary tradecraft into red-team scenarios and hunting hypotheses</li><li><span class="ck"><Icon name="check" /></span> Produce intelligence assessments that inform engagement scoping</li><li><span class="ck"><Icon name="check" /></span> Maintain mappings of relevant techniques to MITRE ATT&amp;CK</li><li><span class="ck"><Icon name="check" /></span> Support hunts and operations with timely, actionable intelligence</li></ul><h2 class="colh">What we are looking for</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Experience in cyber threat intelligence or a closely related discipline</li><li><span class="ck"><Icon name="check" /></span> Strong grasp of adversary tactics, techniques, and the ATT&amp;CK framework</li><li><span class="ck"><Icon name="check" /></span> Ability to turn ambiguous data into clear, decision-ready assessments</li><li><span class="ck"><Icon name="check" /></span> Excellent written communication for technical and executive audiences</li><li><span class="ck"><Icon name="check" /></span> Analytical rigor and structured-analysis discipline</li></ul><h2 class="colh">Nice to have</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Sector specialization in finance, healthcare, or telecom threats</li><li><span class="ck"><Icon name="check" /></span> Hands-on detection engineering or hunting experience</li></ul></div><aside class="dside"><div class="aside-card"><h2>Role details</h2><div class="kv"><span>Team</span><b>Threat Intelligence</b></div><div class="kv"><span>Level</span><b>Mid</b></div><div class="kv"><span>Location</span><b>Remote (UK/EU)</b></div><div class="kv"><span>Type</span><b>Full-time</b></div><div class="kv"><span>Posted</span><b>20 May 2026</b></div></div><a class="btn btn-fill asidebtn" href="mailto:careers@subzerosec.com?subject=Application: Threat Intelligence Analyst">Apply for this role <Icon name="arrow-right" /></a></aside></div></div></section>
<section class="sec light cutC"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="cta-in"><span class="eyebrow">Get ahead of zero</span><h2>Ready to see yourself the way an <span class="r">adversary would?</span></h2><p>Book a scoped assessment - we will map what is reachable, prove what is exploitable, and give you a ranked path to closing it before someone finds it first.</p><a href="contact.html" class="btn btn-fill">Book a free scoping call <Icon name="arrow-right" /></a></div></div></section>
</Base>
