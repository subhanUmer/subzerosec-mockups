---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
const title = "Red Team Operator - Careers - SubZeroSec";
const description = "Run objective-based adversary emulation against mature, defended environments and measure how well clients can detect and respond.";
---
<Base title={title} description={description} active="company">
<section class="phead">
  <div class="phbg" aria-hidden="true"></div>
  <div class="wrap">
    <div class="crumb"><a href="index.html">Home</a> <i>/</i> <a href="careers.html">Careers</a> <i>/</i> <span>Red Team Operator</span></div><span class="eyebrow">Adversary Emulation</span>
    <h1>Red Team Operator</h1>
    <p class="lead">Adversary Emulation &amp;middot; Mid-Senior &amp;middot; Remote (UK/EU) &amp;middot; Full-time</p>
  </div>
</section>
<section class="sec light cutA"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="detail"><div class="dprose"><p class="rolesummary">Run objective-based adversary emulation against mature, defended environments and measure how well clients can detect and respond.</p><h3 class="colh">What you will do</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Plan and execute covert, objective-based red-team operations</li><li><span class="ck"><Icon name="check" /></span> Develop initial access, escalation, lateral movement, and persistence under detection thresholds</li><li><span class="ck"><Icon name="check" /></span> Map every action to MITRE ATT&amp;CK and document detection gaps and response timing</li><li><span class="ck"><Icon name="check" /></span> Run purple-team replays to help blue teams build durable detections</li><li><span class="ck"><Icon name="check" /></span> Build and maintain tradecraft, infrastructure, and tooling that evades modern defenses</li></ul><h3 class="colh">What we are looking for</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Demonstrable red-team or advanced penetration testing experience</li><li><span class="ck"><Icon name="check" /></span> Strong Active Directory and Windows internals knowledge</li><li><span class="ck"><Icon name="check" /></span> Familiarity with C2 frameworks, evasion, and operational security</li><li><span class="ck"><Icon name="check" /></span> Working fluency with the MITRE ATT&amp;CK framework</li><li><span class="ck"><Icon name="check" /></span> Sound judgment operating quietly in live production environments</li></ul><h3 class="colh">Nice to have</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Malware development or evasion research background</li><li><span class="ck"><Icon name="check" /></span> Social engineering or physical intrusion experience</li></ul></div><aside class="dside"><div class="aside-card"><h4>Role details</h4><div class="kv"><span>Team</span><b>Adversary Emulation</b></div><div class="kv"><span>Level</span><b>Mid-Senior</b></div><div class="kv"><span>Location</span><b>Remote (UK/EU)</b></div><div class="kv"><span>Type</span><b>Full-time</b></div><div class="kv"><span>Posted</span><b>2 May 2026</b></div></div><a class="btn btn-fill asidebtn" href="mailto:careers@subzerosec.com?subject=Application: Red Team Operator">Apply for this role <Icon name="arrow-right" /></a></aside></div></div></section>
<section class="sec light cutC"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="cta-in"><span class="eyebrow">Get ahead of zero</span><h2>Ready to see yourself the way an <span class="r">adversary would?</span></h2><p>Book a scoped assessment - we will map what is reachable, prove what is exploitable, and give you a ranked path to closing it before someone finds it first.</p><a href="contact.html" class="btn btn-fill">Book a free scoping call <Icon name="arrow-right" /></a></div></div></section>
</Base>
