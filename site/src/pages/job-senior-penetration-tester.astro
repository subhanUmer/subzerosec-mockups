---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
const title = "Senior Penetration Tester - Careers - SubZeroSec";
const description = "Lead manual, exploit-driven assessments across web, API, network, and cloud targets, and set the technical bar for the findings we ship.";
---
<Base title={title} description={description} active="company">
<section class="phead">
  <div class="phbg" aria-hidden="true"></div>
  <div class="wrap">
    <div class="crumb"><a href="index.html">Home</a> <i>/</i> <a href="careers.html">Careers</a> <i>/</i> <span>Senior Penetration Tester</span></div><span class="eyebrow">Offensive Security</span>
    <h1>Senior Penetration Tester</h1>
    <p class="lead">Offensive Security &amp;middot; Senior &amp;middot; Remote (UK/EU) &amp;middot; Full-time</p>
  </div>
</section>
<section class="sec light cutA"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="detail"><div class="dprose"><p class="rolesummary">Lead manual, exploit-driven assessments across web, API, network, and cloud targets, and set the technical bar for the findings we ship.</p><h3 class="colh">What you will do</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Plan and deliver penetration tests across web applications, APIs, networks, and cloud</li><li><span class="ck"><Icon name="check" /></span> Manually exploit and chain vulnerabilities to prove real business impact</li><li><span class="ck"><Icon name="check" /></span> Write clear, prioritized reports that engineers can act on and leaders can understand</li><li><span class="ck"><Icon name="check" /></span> Brief clients on findings and support them through remediation and retest</li><li><span class="ck"><Icon name="check" /></span> Mentor junior testers and contribute to internal tooling and methodology</li></ul><h3 class="colh">What we are looking for</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Several years of hands-on penetration testing across multiple target types</li><li><span class="ck"><Icon name="check" /></span> Deep, practical knowledge of web and API exploitation beyond automated tooling</li><li><span class="ck"><Icon name="check" /></span> Comfort operating in at least one major cloud provider</li><li><span class="ck"><Icon name="check" /></span> Strong written communication - your reports are the product</li><li><span class="ck"><Icon name="check" /></span> A relevant certification such as OSCP, CREST, or equivalent demonstrable skill</li></ul><h3 class="colh">Nice to have</h3><ul class="checks"><li><span class="ck"><Icon name="check" /></span> Cloud or mobile security specialization</li><li><span class="ck"><Icon name="check" /></span> Published research, tooling, or conference talks</li></ul></div><aside class="dside"><div class="aside-card"><h4>Role details</h4><div class="kv"><span>Team</span><b>Offensive Security</b></div><div class="kv"><span>Level</span><b>Senior</b></div><div class="kv"><span>Location</span><b>Remote (UK/EU)</b></div><div class="kv"><span>Type</span><b>Full-time</b></div><div class="kv"><span>Posted</span><b>15 Apr 2026</b></div></div><a class="btn btn-fill asidebtn" href="mailto:careers@subzerosec.com?subject=Application: Senior Penetration Tester">Apply for this role <Icon name="arrow-right" /></a></aside></div></div></section>
<section class="sec light cutC"><div class="geo" aria-hidden="true"></div><div class="wrap"><div class="cta-in"><span class="eyebrow">Get ahead of zero</span><h2>Ready to see yourself the way an <span class="r">adversary would?</span></h2><p>Book a scoped assessment - we will map what is reachable, prove what is exploitable, and give you a ranked path to closing it before someone finds it first.</p><a href="contact.html" class="btn btn-fill">Book a free scoping call <Icon name="arrow-right" /></a></div></div></section>
</Base>
