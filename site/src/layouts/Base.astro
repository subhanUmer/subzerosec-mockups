---
import Header from '../components/Header.astro';
import MobileNav from '../components/MobileNav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  active?: string;
}
const { title, description, active } = Astro.props;

// One-line cache-bust for the shared stylesheet + script (they live in /public,
// so Astro does not fingerprint them). Bump when szs.css / szs.js change.
const V = '9';
const fonts ='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600;700&family=Sora:wght@600;700;800&display=swap';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content="assets/logo.png" />
<meta name="twitter:card" content="summary" />
<link rel="icon" href="assets/logo.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={fonts} rel="stylesheet" />
<link rel="stylesheet" href={`assets/szs.css?v=${V}`} />
</head>
<body>
<Header active={active} />
<MobileNav />
<slot />
<Footer />
<script src={`assets/szs.js?v=${V}`}></script>
</body>
</html>
